<!DOCTYPE listaClientes [
    <!ELEMENT listaClientes (cliente+)>
    <!ELEMENT cliente (nombre, diaEntrega+)>
    <!ATTLIST cliente cif CDATA #REQUIRED>
    <!ELEMENT nombre (#PCDATA)>
    <!ELEMENT diaEntrega (#PCDATA)>
]>

<listaClientes>

    <cliente cif="5676443">
        <nombre>Mercasa</nombre>
        <diaEntrega>Lunes</diaEntrega>
        <diaEntrega>Martes</diaEntrega>
    </cliente>

    <cliente cif="5121554">
        <nombre>Acer SL</nombre>
        <diaEntrega>Lunes</diaEntrega>

    </cliente>
</listaClientes> 